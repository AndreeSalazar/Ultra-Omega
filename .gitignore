# ═══════════════════════════════════════════════════════════════════════════════
# Ultra-Omega: Git Ignore
# Excluye solo archivos de build y temporales
# ═══════════════════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════
# RUST - Build artifacts
# ══════════════════════════════════════════
/target/
**/*.rs.bk
**/*.pdb

# ══════════════════════════════════════════
# ARCHIVOS COMPILADOS Y EJECUTABLES
# ══════════════════════════════════════════
# Ejecutables
*.exe
*.out
*.app
*.bin

# Objetos compilados
*.obj
*.o
*.so
*.dylib
*.dll
*.a
*.lib

# ══════════════════════════════════════════
# ARCHIVOS TEMPORALES DE LA APLICACIÓN
# ══════════════════════════════════════════
# Archivos temporales generados por el terminal/compilación
temp.*
*.tmp
# Ejecutables generados por compilación (excluir solo en raíz y directorios de trabajo)
/program.exe
/program
/program.out
a.out

# ══════════════════════════════════════════
# ARCHIVOS DEL SISTEMA OPERATIVO
# ══════════════════════════════════════════
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# ══════════════════════════════════════════
# ARCHIVOS DEL EDITOR/IDE
# ══════════════════════════════════════════
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Cursor
.cursor/

# ══════════════════════════════════════════
# LOGS Y BACKUPS
# ══════════════════════════════════════════
*.log
*.swp
*.swo
*~
*.bak
*.backup

# ══════════════════════════════════════════
# DEPENDENCIAS Y PAQUETES
# ══════════════════════════════════════════
# Cargo.lock se incluye para aplicaciones binarias (seguimos la práctica estándar)
# Si prefieres excluirlo, descomenta la siguiente línea:
# Cargo.lock

# Node modules (si se agrega soporte JavaScript/TypeScript en el futuro)
node_modules/

# Python (si se agrega soporte Python en el futuro)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv

# ══════════════════════════════════════════
# ARCHIVOS ESPECÍFICOS DE BUILD
# ══════════════════════════════════════════
# CMake (solo archivos generados, no los templates)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
# Makefile generado por CMake (no los templates en src/templates)
# Los Makefiles en src/templates/ se incluyen
**/CMakeFiles/
**/CMakeCache.txt
*.cmake
!CMakeLists.txt
!**/CMakeLists.txt
!**/Makefile
!**/makefile

# Build directories (solo directorios build/, no archivos build.*)
/build/
/dist/
/out/
/bin/  # Solo si contiene ejecutables compilados en la raíz

# ══════════════════════════════════════════
# CONFIGURACIÓN LOCAL (opcional - descomenta si quieres excluir)
# ══════════════════════════════════════════
# Configuración local del usuario
# config.local.json
# .env.local

# ══════════════════════════════════════════
# NOTA: TODO LO DEMÁS SE INCLUYE
# ══════════════════════════════════════════
# Se incluyen:
# - Todo el código fuente (.rs, .asm, .c, .cpp, .zig, etc.)
# - Templates y recursos
# - Documentación (.md)
# - Scripts de build (.sh, .bat, Makefile, etc.)
# - Configuraciones del proyecto (Cargo.toml, etc.)
