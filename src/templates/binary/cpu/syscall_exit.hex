; ═══════════════════════════════════════════════════════════════════════════════
; ULTRA-OMEGA BINARY TEMPLATE: syscall_exit
; Arquitectura: x86_64 Linux
; Tamaño: 12 bytes
; ═══════════════════════════════════════════════════════════════════════════════

; ─────────────────────────────────────────────────────────────────────────────
; PARÁMETROS INYECTABLES:
;   [EXIT_CODE] @ offset 0x07 (4 bytes) - Código de salida
; ─────────────────────────────────────────────────────────────────────────────

; === CÓDIGO ===

0x00: 48 C7 C0 3C 00 00 00    ; mov rax, 60            | syscall: exit (0x3C = 60)
0x07: 48 C7 C7               ; mov rdi, (inicio)
0x07: [CODE 4 BYTES]         ; ... EXIT_CODE          | ← PARÁMETRO: exit_code
0x0B: 0F 05                  ; syscall                | ejecutar (no retorna)

; ═══════════════════════════════════════════════════════════════════════════════
; BYTECODE CON PLACEHOLDERS (0xFF = parámetro):
; ═══════════════════════════════════════════════════════════════════════════════
;
; 48 C7 C0 3C 00 00 00       ; mov rax, 60 (exit)
; 48 C7 C7 FF FF FF FF       ; mov rdi, [EXIT_CODE]
; 0F 05                      ; syscall
;
; ═══════════════════════════════════════════════════════════════════════════════

; ─────────────────────────────────────────────────────────────────────────────
; VERSIÓN OPTIMIZADA (si exit_code = 0):
; ─────────────────────────────────────────────────────────────────────────────
;
; 48 C7 C0 3C 00 00 00       ; mov rax, 60
; 48 31 FF                   ; xor rdi, rdi (rdi = 0)
; 0F 05                      ; syscall
;
; Total: 12 bytes
; ═══════════════════════════════════════════════════════════════════════════════

