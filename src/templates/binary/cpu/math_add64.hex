; ═══════════════════════════════════════════════════════════════════════════════
; ULTRA-OMEGA BINARY TEMPLATE: math_add64
; Arquitectura: x86_64
; Tamaño: 6 bytes
; ═══════════════════════════════════════════════════════════════════════════════

; ─────────────────────────────────────────────────────────────────────────────
; FUNCIÓN: int64 add64(int64 a, int64 b)
;   Entrada: rdi = a, rsi = b (System V ABI)
;   Salida:  rax = a + b
; ─────────────────────────────────────────────────────────────────────────────

; === CÓDIGO ===

0x00: 48 89 F8                ; mov rax, rdi           | rax = a
0x03: 48 01 F0                ; add rax, rsi           | rax = a + b
0x06: C3                      ; ret                    | retornar resultado

; ═══════════════════════════════════════════════════════════════════════════════
; BYTECODE COMPLETO:
; ═══════════════════════════════════════════════════════════════════════════════
;
; 48 89 F8 48 01 F0 C3
;
; ═══════════════════════════════════════════════════════════════════════════════

; ─────────────────────────────────────────────────────────────────────────────
; VARIANTES OPTIMIZADAS:
; ─────────────────────────────────────────────────────────────────────────────

; Versión LEA (también 7 bytes, pero puede ser más rápida en algunos CPUs):
; 0x00: 48 8D 04 37             ; lea rax, [rdi+rsi]    | rax = a + b
; 0x04: C3                      ; ret

; ═══════════════════════════════════════════════════════════════════════════════

