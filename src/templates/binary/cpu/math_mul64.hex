; ═══════════════════════════════════════════════════════════════════════════════
; ULTRA-OMEGA BINARY TEMPLATE: math_mul64
; Arquitectura: x86_64
; Tamaño: 7 bytes
; ═══════════════════════════════════════════════════════════════════════════════

; ─────────────────────────────────────────────────────────────────────────────
; FUNCIÓN: int64 mul64(int64 a, int64 b)
;   Entrada: rdi = a, rsi = b
;   Salida:  rax = a * b (64 bits bajos)
; ─────────────────────────────────────────────────────────────────────────────

; === CÓDIGO ===

0x00: 48 89 F8                ; mov rax, rdi           | rax = a
0x03: 48 0F AF C6             ; imul rax, rsi          | rax = a * b
0x07: C3                      ; ret                    | retornar

; ═══════════════════════════════════════════════════════════════════════════════
; BYTECODE COMPLETO:
; ═══════════════════════════════════════════════════════════════════════════════
;
; 48 89 F8 48 0F AF C6 C3
;
; ═══════════════════════════════════════════════════════════════════════════════

