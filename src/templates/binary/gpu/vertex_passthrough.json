{
  "template_name": "vertex_passthrough",
  "template_type": "gpu_spirv",
  "api": "Vulkan 1.3",
  "spirv_version": "1.3",
  "description": "Vertex shader básico - pasa posición y color sin transformación",
  "binary_file": "vertex_passthrough.spv",
  "hex_file": "vertex_passthrough.spv.hex",
  "size_bytes": 512,
  "shader_stage": "vertex",
  "entry_point": "main",
  "inputs": [
    {
      "name": "inPosition",
      "location": 0,
      "type": "vec3",
      "description": "Posición del vértice"
    },
    {
      "name": "inColor",
      "location": 1,
      "type": "vec3",
      "description": "Color del vértice"
    }
  ],
  "outputs": [
    {
      "name": "gl_Position",
      "builtin": true,
      "type": "vec4",
      "description": "Posición transformada"
    },
    {
      "name": "fragColor",
      "location": 0,
      "type": "vec3",
      "description": "Color para fragment shader"
    }
  ],
  "parameters": [],
  "glsl_equivalent": "vertex_passthrough.glsl"
}

