; ULTRA-OMEGA GPU TEMPLATE: vertex_passthrough
; SPIR-V Bytecode (Vulkan 1.3, SPIR-V 1.3)
; ═══════════════════════════════════════════════════════════════════════════════

; ─────────────────────────────────────────────────────────────────────────────
; HEADER SPIR-V
; ─────────────────────────────────────────────────────────────────────────────

0x00000000: 03 02 23 07          ; Magic Number (SPIR-V)
0x00000004: 00 01 03 00          ; Version 1.3.0
0x00000008: 00 00 00 00          ; Generator: Ultra-Omega
0x0000000C: XX XX XX XX          ; Bound (número más alto de ID + 1)
0x00000010: 00 00 00 00          ; Schema (reserved)

; ─────────────────────────────────────────────────────────────────────────────
; CAPABILITIES & EXTENSIONS
; ─────────────────────────────────────────────────────────────────────────────

; OpCapability Shader
0x00000014: 11 00 02 00 01 00 00 00

; OpMemoryModel Logical GLSL450
0x0000001C: 0E 00 03 00 00 00 00 00 01 00 00 00

; OpEntryPoint Vertex %main "main" %inPosition %inColor %gl_Position %fragColor
; (Los IDs y offsets varían según la compilación)

; ─────────────────────────────────────────────────────────────────────────────
; DECORATIONS
; ─────────────────────────────────────────────────────────────────────────────

; OpDecorate %inPosition Location 0
; OpDecorate %inColor Location 1
; OpDecorate %gl_Position BuiltIn Position
; OpDecorate %fragColor Location 0

; ─────────────────────────────────────────────────────────────────────────────
; TYPES & VARIABLES
; ─────────────────────────────────────────────────────────────────────────────

