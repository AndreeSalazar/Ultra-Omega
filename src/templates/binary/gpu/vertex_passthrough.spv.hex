; %func = OpTypeFunction %void
; %float = OpTypeFloat 32
; %vec3 = OpTypeVector %float 3
; %vec4 = OpTypeVector %float 4
; %ptr_input_vec3 = OpTypePointer Input %vec3
; %ptr_output_vec3 = OpTypePointer Output %vec3
; %ptr_output_vec4 = OpTypePointer Output %vec4

; %inPosition = OpVariable %ptr_input_vec3 Input
; %inColor = OpVariable %ptr_input_vec3 Input
; %gl_Position = OpVariable %ptr_output_vec4 Output
; %fragColor = OpVariable %ptr_output_vec3 Output

; ─────────────────────────────────────────────────────────────────────────────
; FUNCTION: main
; ─────────────────────────────────────────────────────────────────────────────

