{
  "template_name": "vertex_mvp",
  "template_type": "gpu_spirv",
  "api": "Vulkan 1.3",
  "spirv_version": "1.3",
  "description": "Vertex shader con transformación MVP (Model-View-Projection)",
  "binary_file": "vertex_mvp.spv",
  "hex_file": "vertex_mvp.spv.hex",
  "size_bytes": 768,
  "shader_stage": "vertex",
  "entry_point": "main",
  "inputs": [
    {
      "name": "inPosition",
      "location": 0,
      "type": "vec3",
      "description": "Posición del vértice en espacio local"
    },
    {
      "name": "inColor",
      "location": 1,
      "type": "vec3",
      "description": "Color del vértice"
    },
    {
      "name": "inTexCoord",
      "location": 2,
      "type": "vec2",
      "description": "Coordenadas de textura"
    }
  ],
  "outputs": [
    {
      "name": "gl_Position",
      "builtin": true,
      "type": "vec4",
      "description": "Posición en clip space"
    },
    {
      "name": "fragColor",
      "location": 0,
      "type": "vec3",
      "description": "Color para fragment shader"
    },
    {
      "name": "fragTexCoord",
      "location": 1,
      "type": "vec2",
      "description": "UV para fragment shader"
    }
  ],
  "uniform_buffers": [
    {
      "binding": 0,
      "set": 0,
      "name": "UniformBufferObject",
      "members": [
        {"name": "model", "type": "mat4"},
        {"name": "view", "type": "mat4"},
        {"name": "proj", "type": "mat4"}
      ]
    }
  ],
  "parameters": [
    {
      "name": "ubo_binding",
      "type": "descriptor_binding",
      "offset": 156,
      "size": 4,
      "default": 0,
      "description": "Binding del uniform buffer MVP"
    }
  ],
  "glsl_equivalent": "vertex_mvp.glsl"
}

