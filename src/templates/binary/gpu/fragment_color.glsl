// ═══════════════════════════════════════════════════════════════════════════════
// ULTRA-OMEGA GPU TEMPLATE: fragment_color
// GLSL Equivalente para referencia (compilar con glslc a SPIR-V)
// ═══════════════════════════════════════════════════════════════════════════════

#version 450

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS (desde vertex shader, interpolados)
// ─────────────────────────────────────────────────────────────────────────────
layout(location = 0) in vec3 fragColor;

// ─────────────────────────────────────────────────────────────────────────────
// OUTPUTS (hacia framebuffer)
// ─────────────────────────────────────────────────────────────────────────────
layout(location = 0) out vec4 outColor;

// ─────────────────────────────────────────────────────────────────────────────
// MAIN
// ─────────────────────────────────────────────────────────────────────────────
void main() {
    // Output color con alpha = 1.0
    outColor = vec4(fragColor, 1.0);
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPILACIÓN:
//   glslc fragment_color.glsl -o fragment_color.spv
// ═══════════════════════════════════════════════════════════════════════════════

